generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "sqlite"
}

model Spot {
    id           String     @id @default(cuid())
    slug         String     @unique
    name         String
    description  String
    content      String
    neighborhood String
    category     String
    featured     Boolean    @default(false)
    createdAt    DateTime   @default(now())
    updatedAt    DateTime   @updatedAt
    tips         Tip[]
    favorites    Favorite[]
}

model Tip {
    id        String   @id @default(cuid())
    content   String
    author    String
    spot      Spot     @relation(fields: [spotSlug], references: [slug], onDelete: Cascade)
    spotSlug  String
    createdAt DateTime @default(now())
}

model Favorite {
    id       String @id @default(cuid())
    userId   String
    spot     Spot   @relation(fields: [spotSlug], references: [slug], onDelete: Cascade)
    spotSlug String

    @@unique([userId, spotSlug])
}
