generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

// PostgreSQL (Vercel) — for SQLite local dev, change to "sqlite"
datasource db {
    provider = "postgresql"
}

model Event {
    id          String     @id @default(cuid())
    slug        String     @unique
    name        String
    description String
    day         String
    labels      String     @default("")
    time        String
    speaker     String?
    location    String
    createdAt   DateTime   @default(now())
    comments    Comment[]
    questions   Question[]
    favorites   Favorite[]
}

model Comment {
    id        String        @id @default(cuid())
    content   String
    userName  String
    likes     Int           @default(0)
    event     Event         @relation(fields: [eventSlug], references: [slug], onDelete: Cascade)
    eventSlug String
    commentLikes CommentLike[]
    createdAt DateTime      @default(now())
}

model CommentLike {
    id        String  @id @default(cuid())
    userName  String
    comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
    commentId String

    @@unique([userName, commentId])
}

model Question {
    id        String         @id @default(cuid())
    content   String
    userName  String
    votes     Int            @default(0)
    event     Event          @relation(fields: [eventSlug], references: [slug], onDelete: Cascade)
    eventSlug String
    questionVotes QuestionVote[]
    createdAt DateTime       @default(now())
}

model QuestionVote {
    id         String   @id @default(cuid())
    userName   String
    question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
    questionId String

    @@unique([userName, questionId])
}

model Favorite {
    id        String @id @default(cuid())
    userName  String
    event     Event  @relation(fields: [eventSlug], references: [slug], onDelete: Cascade)
    eventSlug String

    @@unique([userName, eventSlug])
}